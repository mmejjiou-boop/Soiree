{% extends 'base.html.twig' %}

{% block title %}Dj index{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto p-6">
    <h1 class="text-3xl font-bold mb-6 text-gray-800">Dj index</h1>

    <div class="overflow-x-auto bg-white shadow-md rounded-lg">
        <table class="min-w-full border border-gray-200">
            <thead class="bg-gray-100">
                <tr>
                    <th class="px-4 py-2 text-left text-sm font-semibold text-gray-600">Id</th>
                    <th class="px-4 py-2 text-left text-sm font-semibold text-gray-600">Nom</th>
                    <th class="px-4 py-2 text-left text-sm font-semibold text-gray-600">Style</th>
                    <th class="px-4 py-2 text-left text-sm font-semibold text-gray-600">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for dj in djs %}
                <tr class="border-t hover:bg-gray-50">
                    <td class="px-4 py-2">{{ dj.id }}</td>
                    <td class="px-4 py-2 font-medium text-gray-800">{{ dj.nom }}</td>
                    <td class="px-4 py-2 text-gray-600">{{ dj.style }}</td>
                    <td class="px-4 py-2 flex gap-2 items-center">

                        <a href="{{ path('app_dj_show', {'id': dj.id}) }}"
                           class="text-blue-500 hover:underline">
                           Voir
                        </a>

                        <a href="{{ path('app_dj_edit', {'id': dj.id}) }}"
                           class="text-yellow-500 hover:underline">
                           Modifier
                        </a>

                        <form method="post"
                              action="{{ path('app_dj_delete', {'id': dj.id}) }}"
                              onsubmit="return confirm('Supprimer ce DJ ?');">

                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dj.id) }}">

                            <button class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-sm"
                                    type="submit">
                                Supprimer
                            </button>
                        </form>

                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-4 text-gray-500">
                        Aucun DJ trouvé
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="mt-6">
        <a href="{{ path('app_dj_new') }}"
           class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded shadow">
             Ajouter un nouveau DJ
        </a>
    </div>
</div>
{% endblock %}