{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

<h1 class="text-3xl font-bold mb-6">Soirées</h1>

<a href="{{ path('soiree_new') }}"
   class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6 inline-block">
    Ajouter une soirée
</a>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    {% for soiree in soirees %}
        <div class="bg-white p-5 rounded-xl shadow">

            <h2 class="text-xl font-semibold">
                {{ soiree.titre }}
            </h2>

            <p class="text-gray-500 text-sm mt-1">
                {{ soiree.dateSoiree|date('d/m/Y H:i') }}
            </p>

            <p class="mt-2 text-sm">
                Thème :
                <span class="font-medium">
                    {{ soiree.theme ? soiree.theme.nom : 'Aucun' }}
                </span>
            </p>

            <div class="mt-2 text-sm">
                DJs :
                {% for dj in soiree.djs %}
                    <span class="bg-gray-200 px-2 py-1 rounded text-xs mr-1">
                        {{ dj.nom }}
                    </span>
                {% else %}
                    <span class="text-gray-400">Aucun DJ</span>
                {% endfor %}
            </div>

            <div class="mt-4 flex gap-3 text-sm">
                <a href="{{ path('soiree_edit', {id: soiree.id}) }}"
                   class="text-yellow-600 hover:underline">
                    Modifier
                </a>

                <a href="{{ path('soiree_delete', {id: soiree.id}) }}"
                   class="text-red-600 hover:underline"
                   onclick="return confirm('Supprimer ?')">
                    Supprimer
                </a>
            </div>

        </div>
    {% endfor %}

</div>

{% endblock %}