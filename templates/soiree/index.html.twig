<h1>Soirées</h1>

<a href="/soiree/new">Ajouter</a>

<ul>
    {% for soiree in soirees %}
        <li>
            <strong>{{ soiree.titre }}</strong>
            ({{ soiree.dateSoiree|date('d/m/Y') }})

            <a href="/soiree/{{ soiree.id }}/edit">Modifier</a>
            <a href="/soiree/{{ soiree.id }}/delete">Supprimer</a>
        </li>
    {% endfor %}
</ul>