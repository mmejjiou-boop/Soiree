{% extends 'base.html.twig' %}

{% block title %}Soirées{% endblock %}

{% block body %}

<div class="min-h-screen bg-gray-100 py-10">

    <div class="max-w-4xl mx-auto bg-white shadow-lg rounded-2xl p-8">

        <!-- TITRE -->
        <h1 class="text-4xl font-bold text-center text-gray-800 mb-8">
            Soirées
        </h1>

        <!-- BOUTON AJOUT -->
        <div class="flex justify-center mb-8">
            <a href="{{ path('soiree_new') }}"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl transition shadow">
                Ajouter une soirée
            </a>
        </div>

        <!-- LISTE -->
        <div class="space-y-5">

            {% for soiree in soirees %}

                <div class="bg-gray-50 rounded-xl p-5 shadow-sm hover:shadow-md transition">

                    <div class="flex justify-between items-start">

                        <!-- INFOS -->
                        <div>

                            <h2 class="text-xl font-semibold text-gray-800">
                                {{ soiree.titre }}
                            </h2>

                            <p class="text-sm text-gray-500 mt-1">
                                {{ soiree.dateSoiree|date('d/m/Y H:i') }}
                            </p>

                            <!-- DJ -->
                            <div class="mt-3 text-sm text-gray-700">

                                <span class="font-medium">DJ :</span>

                                {% for dj in soiree.djs %}

                                    <a href="{{ path('app_dj_show', {'id': dj.id}) }}"
                                       class="text-blue-600 hover:underline">
                                        {{ dj.nom }}
                                    </a>

                                    {% if not loop.last %}, {% endif %}

                                {% else %}

                                    <span class="text-gray-400">Aucun DJ</span>

                                {% endfor %}

                            </div>

                        </div>

                        <!-- ACTIONS -->
                        <div class="flex gap-4 text-sm">

                            <a href="{{ path('soiree_edit', {'id': soiree.id}) }}"
                               class="text-yellow-600 hover:text-yellow-700">
                                Modifier
                            </a>

                            <form method="post"
                                  action="{{ path('soiree_delete', {'id': soiree.id}) }}"
                                  onsubmit="return confirm('Supprimer cette soirée ?');">

                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete' ~ soiree.id) }}">

                                <button type="submit"
                                        class="text-red-600 hover:text-red-700">
                                    Supprimer
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            {% else %}

                <div class="text-center text-gray-500 py-10">
                    Aucune soirée disponible
                </div>

            {% endfor %}

        </div>

    </div>

</div>

{% endblock %}