{% extends 'base.html.twig' %}

{% block title %}Soirées{% endblock %}

{% block body %}

<div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Soirées</h1>

    <a href="{{ path('soiree_new') }}"
       class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
        Ajouter une soirée
    </a>
</div>

<div class="space-y-4">

    {% for soiree in soirees %}
        <div class="bg-white rounded-xl shadow p-5 flex justify-between items-center">

            <div>
                <h2 class="text-xl font-semibold text-gray-800">
                    {{ soiree.titre }}
                </h2>

                <p class="text-sm text-gray-500 mt-1">
                    {{ soiree.dateSoiree|date('d/m/Y H:i') }}
                </p>

                <p class="text-sm mt-2">
                    Thème :
                    <span class="font-medium text-gray-700">
                        {{ soiree.theme ? soiree.theme.nom : 'Aucun' }}
                    </span>
                </p>

                <p class="text-sm mt-2">
                    DJs :
                    {% for dj in soiree.djs %}
                        <span class="inline-block bg-gray-200 text-gray-700 px-2 py-1 rounded text-xs mr-1">
                            {{ dj.nom }}
                        </span>
                    {% else %}
                        <span class="text-gray-400">Aucun DJ</span>
                    {% endfor %}
                </p>
            </div>

            <div class="flex gap-3 text-sm">

                <a href="{{ path('soiree_edit', {id: soiree.id}) }}"
                   class="text-yellow-600 hover:underline">
                    Modifier
                </a>

                <a href="{{ path('soiree_delete', {id: soiree.id}) }}"
                   class="text-red-600 hover:underline"
                   onclick="return confirm('Supprimer cette soirée ?')">
                    Supprimer
                </a>

            </div>

        </div>
    {% else %}
        <div class="bg-white p-6 rounded-xl shadow text-gray-500">
            Aucune soirée pour le moment
        </div>
    {% endfor %}

</div>

{% endblock %}